{
  "description": "ResiRed - Flow 3: Alertas comunidad y canal comunitario broadcast",
  "states": [
    {
      "name": "Trigger",
      "type": "trigger",
      "transitions": [
        { "event": "incomingMessage", "next": null },
        { "event": "incomingCall", "next": null },
        { "event": "incomingRequest", "next": "EvaluarTipoAlerta" }
      ],
      "properties": {
        "offset": { "x": 300, "y": 0 }
      }
    },
    {
      "name": "EvaluarTipoAlerta",
      "type": "split-based-on",
      "transitions": [
        {
          "event": "match",
          "conditions": [
            {
              "friendly_name": "Es alerta de emergencia CVA",
              "arguments": ["{{trigger.request.parameters.tipo_alerta}}"],
              "type": "matches_any_of",
              "value": "cva_activado,alerta_rojo,alerta_naranja"
            }
          ],
          "next": "EnviarAlertaCVA"
        },
        {
          "event": "match",
          "conditions": [
            {
              "friendly_name": "Es alerta preventiva amarilla",
              "arguments": ["{{trigger.request.parameters.tipo_alerta}}"],
              "type": "equal_to",
              "value": "alerta_amarillo"
            }
          ],
          "next": "EnviarAlertaPreventiva"
        },
        {
          "event": "match",
          "conditions": [
            {
              "friendly_name": "Es contenido del canal comunitario",
              "arguments": ["{{trigger.request.parameters.tipo_alerta}}"],
              "type": "equal_to",
              "value": "canal_contenido"
            }
          ],
          "next": "EnviarContenidoCanal"
        },
        {
          "event": "noMatch",
          "next": "ErrorTipoDesconocido"
        }
      ],
      "properties": {
        "input": "{{trigger.request.parameters.tipo_alerta}}",
        "offset": { "x": 300, "y": 160 }
      }
    },
    {
      "name": "EnviarAlertaCVA",
      "type": "make-http-request",
      "transitions": [
        { "event": "success", "next": "RegistrarEnvioExitoso" },
        { "event": "fail", "next": "RegistrarEnvioFallido" }
      ],
      "properties": {
        "offset": { "x": 0, "y": 380 },
        "method": "POST",
        "url": "REEMPLAZAR_CON_URL_AZURE/dispatcher/send",
        "body": "Destinatario={{trigger.request.parameters.destinatario | url_encode}}&Perfil=comunidad&NivelAlerta={{trigger.request.parameters.nivel_alerta | url_encode}}&EventoId={{trigger.request.parameters.evento_id | url_encode}}&Nombre={{trigger.request.parameters.nombre | url_encode}}&Zona={{trigger.request.parameters.zona | url_encode}}&EsAdultoMayor={{trigger.request.parameters.es_adulto_mayor | url_encode}}",
        "content_type": "application/x-www-form-urlencoded",
        "timeout": "30",
        "parameters": [
          {
            "key": "From",
            "value": "{{flow.channel.address}}"
          },
          {
            "key": "To",
            "value": "{{trigger.request.parameters.destinatario}}"
          },
          {
            "key": "Body",
            "value": "{{trigger.request.parameters.mensaje}}"
          }
        ]
      }
    },
    {
      "name": "EnviarAlertaPreventiva",
      "type": "send-message",
      "transitions": [
        { "event": "sent", "next": "RegistrarEnvioExitoso" }
      ],
      "properties": {
        "offset": { "x": 300, "y": 380 },
        "from": "{{flow.channel.address}}",
        "to": "{{trigger.request.parameters.destinatario}}",
        "body": "AVISO RESIRED - NIVEL AMARILLO\n\nSe monitorea una perturbacion meteorologica en el Caribe. Por ahora no representa peligro inmediato.\n\nRECOMENDACIONES:\nMantenga atencion a las noticias y alertas oficiales\nRevise que su kit de emergencia este listo\nComparta esta informacion con su familia\n\nResiRed - Mercy Corps Colombia"
      }
    },
    {
      "name": "EnviarContenidoCanal",
      "type": "send-message",
      "transitions": [
        { "event": "sent", "next": "RegistrarEnvioExitoso" }
      ],
      "properties": {
        "offset": { "x": 600, "y": 380 },
        "from": "{{flow.channel.address}}",
        "to": "{{trigger.request.parameters.destinatario}}",
        "body": "{{trigger.request.parameters.mensaje}}"
      }
    },
    {
      "name": "RegistrarEnvioExitoso",
      "type": "make-http-request",
      "transitions": [
        { "event": "success", "next": null },
        { "event": "fail", "next": null }
      ],
      "properties": {
        "offset": { "x": 300, "y": 600 },
        "method": "POST",
        "url": "REEMPLAZAR_CON_URL_AZURE/status/update",
        "body": "Destinatario={{trigger.request.parameters.destinatario | url_encode}}&EventoId={{trigger.request.parameters.evento_id | url_encode}}&Status=entregado&Canal=wa&Timestamp={{now | date: \"%Y-%m-%dT%H:%M:%S\"}}",
        "content_type": "application/x-www-form-urlencoded",
        "timeout": "10"
      }
    },
    {
      "name": "RegistrarEnvioFallido",
      "type": "make-http-request",
      "transitions": [
        { "event": "success", "next": "IntentarSMS" },
        { "event": "fail", "next": "IntentarSMS" }
      ],
      "properties": {
        "offset": { "x": 0, "y": 600 },
        "method": "POST",
        "url": "REEMPLAZAR_CON_URL_AZURE/status/update",
        "body": "Destinatario={{trigger.request.parameters.destinatario | url_encode}}&EventoId={{trigger.request.parameters.evento_id | url_encode}}&Status=fallido_wa&Canal=wa&Timestamp={{now | date: \"%Y-%m-%dT%H:%M:%S\"}}",
        "content_type": "application/x-www-form-urlencoded",
        "timeout": "10"
      }
    },
    {
      "name": "IntentarSMS",
      "type": "send-message",
      "transitions": [
        { "event": "sent", "next": null }
      ],
      "properties": {
        "offset": { "x": 0, "y": 800 },
        "from": "{{flow.channel.address}}",
        "to": "{{trigger.request.parameters.destinatario | remove: 'whatsapp:'}}",
        "body": "ALERTA RESIRED {{trigger.request.parameters.nivel_alerta | upcase}}: Tormenta tropical puede afectar San Andres. Asegure su hogar, prepare kit emergencia. Mas info llame 123. ResiRed-Mercy Corps"
      }
    },
    {
      "name": "ErrorTipoDesconocido",
      "type": "make-http-request",
      "transitions": [
        { "event": "success", "next": null },
        { "event": "fail", "next": null }
      ],
      "properties": {
        "offset": { "x": 900, "y": 380 },
        "method": "POST",
        "url": "REEMPLAZAR_CON_URL_AZURE/errors/log",
        "body": "Error=tipo_alerta_desconocido&Valor={{trigger.request.parameters.tipo_alerta | url_encode}}&Timestamp={{now | date: \"%Y-%m-%dT%H:%M:%S\"}}",
        "content_type": "application/x-www-form-urlencoded",
        "timeout": "10"
      }
    }
  ],
  "initial_state": "Trigger",
  "flags": {
    "allow_concurrent_calls": true
  }
}
