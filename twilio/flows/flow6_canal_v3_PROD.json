      }
    },
    {
      "name": "RegistrarEnvio",
      "type": "make-http-request",
      "transitions": [
        { "event": "success", "next": null },
        { "event": "failed", "next": null }
      ],
      "properties": {
        "offset": { "x": 900, "y": 720 },
        "method": "POST",
        "url": "https://fa-resired-prod.azurewebsites.net/api/status-update",
        "body": "Destinatario={{trigger.request.parameters.destinatario | url_encode}}&Canal=canal_broadcast&Tipo={{trigger.request.parameters.tipo | url_encode}}&Status=enviado",
        "content_type": "application/x-www-form-urlencoded"
      }
    }
  ],
  "initial_state": "Trigger",
  "flags": { "allow_concurrent_calls": true }
}
