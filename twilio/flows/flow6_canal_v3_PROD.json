      }
    },
    {
      "name": "EnviarRecuperacionDia1",
      "type": "send-message",
      "transitions": [
        { "event": "sent", "next": "RegistrarEnvio" },
        { "event": "failed", "next": null }
      ],
      "properties": {
        "offset": { "x": 1100, "y": 500 },
        "from": "{{flow.channel.address}}",
        "to": "{{trigger.request.parameters.destinatario}}",
        "body": "{{trigger.request.parameters.mensaje}}"
      }
    },
    {
      "name": "EnviarRecuperacionDia1EN",
      "type": "send-message",
      "transitions": [
